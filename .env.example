# Variáveis do docker-compose (produção). Copie para .env e ajuste.
# NUNCA commitar o .env real.

# Senha do Postgres (use uma forte)
POSTGRES_PASSWORD=CHANGE_ME

# Chave para assinar o JWT — gere uma:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME

# Admin inicial criado no primeiro seed
ADMIN_EMAIL=admin@pecuaria.local
ADMIN_PASSWORD=CHANGE_ME

# Origens do frontend (mesma origem via nginx; ajuste se necessário)
CORS_ORIGINS=http://localhost:8101

# Documentação da API (/docs). Deixe false em produção.
EXPOSE_DOCS=false

# Token do Cloudflare Tunnel (painel: Zero Trust > Networks > Tunnels > seu túnel)
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME
