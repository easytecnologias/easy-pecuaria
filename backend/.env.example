# Copie para .env e ajuste. NUNCA commitar o .env real.

# Conexao com o Postgres.
# DEV (Windows) via tunel SSH para o servidor: porta local 5433.
DATABASE_URL=postgresql+psycopg://pecuaria:CHANGE_ME@127.0.0.1:5433/pecuaria

# Em producao (API rodando como container no servidor), usar o hostname da rede:
# DATABASE_URL=postgresql+psycopg://pecuaria:CHANGE_ME@postgres:5432/pecuaria

# Chave para assinar JWT (gere uma: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Admin inicial criado no seed (defina uma senha forte antes do primeiro seed)
ADMIN_EMAIL=admin@pecuaria.local
ADMIN_PASSWORD=CHANGE_ME

# CORS (origens do frontend, separadas por virgula)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
